{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and subscription info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subscriptionTier": { "type": "string", "enum": ["free", "pro"] }
      },
      "required": ["uid", "email", "createdAt", "subscriptionTier"]
    },
    "ConversionRecord": {
      "title": "Conversion Record",
      "description": "History of a file conversion.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "type": { "type": "string", "enum": ["image", "document", "audio", "video"] },
        "inputFormat": { "type": "string" },
        "outputFormat": { "type": "string" },
        "inputSize": { "type": "number" },
        "outputSize": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "failed"] },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string", "description": "Optional cloud storage URL" }
      },
      "required": ["uid", "type", "inputFormat", "outputFormat", "createdAt", "status", "fileName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/conversions/{conversionId}": {
      "schema": "ConversionRecord",
      "description": "Global conversion history records"
    }
  }
}
